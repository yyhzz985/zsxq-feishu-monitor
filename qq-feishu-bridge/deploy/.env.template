# 飞书 OpenAPI 认证（使用同步专用 Bot "汤圆"）
FEISHU_APP_ID=REPLACE_WITH_FEISHU_APP_ID
FEISHU_APP_SECRET=REPLACE_WITH_FEISHU_APP_SECRET

# 也可通过 ZSXQ_FEISHU_APP_ID 覆盖（与 ZSXQ Monitor 一致的机制）
# ZSXQ_FEISHU_APP_ID=REPLACE_WITH_SYNC_BOT_APP_ID
# ZSXQ_FEISHU_APP_SECRET=REPLACE_WITH_SYNC_BOT_APP_SECRET

# 飞书目标群（可以多个，逗号分隔）
FEISHU_CHAT_ID=oc_xxxxxxxxxxxx

# NapCat WebSocket 地址
NAPCAT_WS=ws://napcat:3001

# 数据库路径
QQ_BRIDGE_DB=/app/data/qq_bridge.db

# 日志
QQ_BRIDGE_LOG_DIR=/app/logs

# OSS 归档，默认关闭；正式部署时只在服务器私有 .env 中填写真实值
OSS_ENABLED=0
OSS_BUCKET=REPLACE_WITH_OSS_BUCKET
OSS_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com
OSS_ACCESS_KEY_ID=REPLACE_WITH_OSS_ACCESS_KEY_ID
OSS_ACCESS_KEY_SECRET=REPLACE_WITH_OSS_ACCESS_KEY_SECRET
