# === ZSXQ Daily Report .env template ===
# Copy to /opt/zsxq-daily-report/config/.env and fill in real values.
# Do NOT commit the filled file.

# ZSXQ cookie token.
ZSXQ_ACCESS_TOKEN=REPLACE_WITH_ZSXQ_TOKEN

# Fixed target group: 击球区小能手的星球
ZSXQ_DAILY_GROUP_ID=51115584422414
ZSXQ_DAILY_GROUP_NAME=击球区小能手的星球

# Date rule. The systemd service passes --date yesterday.
ZSXQ_DAILY_TIMEZONE=Asia/Shanghai
ZSXQ_DAILY_OUTPUT_DIR=/data/zsxq-daily-report/击球区小能手的星球

# PDF upload target Feishu document.
ZSXQ_DAILY_FEISHU_DOC_URL=REPLACE_WITH_FEISHU_DOCX_URL

# lark-cli identity used for inserting the PDF into the Feishu doc.
# bot is preferred on servers because it does not require QR-code login.
# The bot/app must have write permission to the document.
ZSXQ_DAILY_LARK_CLI=lark-cli
ZSXQ_DAILY_LARK_AS=bot

# Feishu OpenAPI app used to send Markdown/PDF files to your account.
FEISHU_APP_ID=REPLACE_WITH_FEISHU_APP_ID
FEISHU_APP_SECRET=REPLACE_WITH_FEISHU_APP_SECRET

# Send target. For a personal account, prefer union_id because open_id is app-specific.
# You may also use chat_id and set ZSXQ_DAILY_FEISHU_RECEIVE_ID_TYPE=chat_id.
ZSXQ_DAILY_FEISHU_RECEIVE_ID_TYPE=union_id
ZSXQ_DAILY_FEISHU_RECEIVE_ID=REPLACE_WITH_YOUR_UNION_ID
