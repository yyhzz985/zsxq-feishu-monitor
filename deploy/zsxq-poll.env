# Copy to /opt/zsxq-monitor/config/.env on the server.
# Do not commit or share the filled real file.

ZSXQ_ACCESS_TOKEN=REPLACE_WITH_REAL_TOKEN
FEISHU_CHAT_ID=oc_xxx
WATERMARK_TEXT=更新加V：237219265
ZSXQ_SAVE_DIR=/data/zsxq-archive/击球区小能手

# OpenAPI mode removes Node.js/npm/lark-cli dependency.
FEISHU_SEND_MODE=openapi
FEISHU_APP_ID=REPLACE_WITH_FEISHU_APP_ID
FEISHU_APP_SECRET=REPLACE_WITH_FEISHU_APP_SECRET

# Optional fallback only if you explicitly switch FEISHU_SEND_MODE=cli.
# LARK_CLI_PATH=/usr/local/bin/lark-cli
