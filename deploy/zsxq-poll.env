# === ZSXQ Monitor .env template ===
# Copy to /opt/zsxq-monitor/config/.env and fill in real values.
# Do NOT commit the filled file.

# ZSXQ cookie token (from browser after login)
ZSXQ_ACCESS_TOKEN=REPLACE_WITH_YOUR_ZSXQ_TOKEN

# Archive directory for note images
ZSXQ_SAVE_DIR=/data/zsxq-archive/击球区小能手

# Watermark text (semi-transparent, 15-degree rotated)
WATERMARK_TEXT=更新加V：237219265

# Send mode: openapi (recommended) or cli (deprecated)
FEISHU_SEND_MODE=openapi

# Feishu Bot credentials (汤圆 Bot recommended for content sync)
FEISHU_APP_ID=REPLACE_WITH_FEISHU_APP_ID
FEISHU_APP_SECRET=REPLACE_WITH_FEISHU_APP_SECRET

# Primary chat: content + alerts go here
FEISHU_CHAT_ID=oc_xxx

# Optional: separate alert channel (alerts only, no content)
# FEISHU_ALERT_CHAT_ID=oc_xxx

# Optional: extra content-only groups (comma-separated, no alerts)
# FEISHU_CONTENT_CHAT_IDS=oc_xxx,oc_yyy

# Optional: override Feishu app for ZSXQ sync (separate from Hermes bot)
# ZSXQ_FEISHU_APP_ID=REPLACE_WITH_FEISHU_APP_ID
# ZSXQ_FEISHU_APP_SECRET=REPLACE_WITH_FEISHU_APP_SECRET
