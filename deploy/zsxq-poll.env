# Copy to /opt/zsxq-monitor/config/.env on the server.
# Do not commit or share the filled real file.

ZSXQ_ACCESS_TOKEN=REPLACE_WITH_ZSXQ_TOKEN
FEISHU_CHAT_ID=oc_xxx
WATERMARK_TEXT=更新加V：237219265
ZSXQ_SAVE_DIR=/data/zsxq-archive/击球区小能手

# OpenAPI mode — no Node.js/npm/lark-cli needed.
FEISHU_SEND_MODE=openapi

# ZSXQ 同步专用 Bot (汤圆)
# 支持覆盖: ZSXQ_FEISHU_APP_ID 优先于 FEISHU_APP_ID
FEISHU_APP_ID=REPLACE_WITH_FEISHU_APP_ID
FEISHU_APP_SECRET=REPLACE_WITH_FEISHU_APP_SECRET

# 如果 Hermes 总管 Bot 和同步 Bot 是同一个应用, 只设 FEISHU_APP_ID 即可.
# 如果是分开的: 设 ZSXQ_FEISHU_APP_ID 来覆盖.
# ZSXQ_FEISHU_APP_ID=REPLACE_WITH_SYNC_BOT_APP_ID
# ZSXQ_FEISHU_APP_SECRET=REPLACE_WITH_SYNC_BOT_SECRET
